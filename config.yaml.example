# Data source
# If you want to use Google Sheets, set USE_GOOGLE_SHEETS=true and provide the spreadsheet ID
# and the path to a Google Cloud service account JSON key. Share the sheet with that service account email.
USE_GOOGLE_SHEETS: false
GSHEET_SPREADSHEET_ID:
GSHEET_SERVICE_ACCOUNT_JSON: ./credentials/service_account.json

# Excel fallback (used when USE_GOOGLE_SHEETS=false)
EXCEL_PATH: ./assets/ideas.xlsx
SHEET_NAME: Sheet1

# BACKGROUND_VIDEO can be a single mp4 file or a directory containing multiple mp4 files.
# If a directory is specified, one mp4 will be chosen at random per compose.
BACKGROUND_VIDEO: ./assets/background.mp4
OUTPUT_DIR: ./outputs
FONT_PATH: ./assets/fonts/NotoSerifCJKjp-Regular.otf

# Optional: absolute path to ffmpeg executable. If unset, system PATH will be used.
FFMPEG_PATH:

# Defaults
DEFAULT_STATUS_READY: Ready
DEFAULT_STATUS_DONE: Done
